{
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "mcp__ops__*",
      "mcp__onyx-ops__*",
      "mcp__playwright__*"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/stephan/Documents/ops-agent/.claude/hooks/find-guard.py"
          }
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/stephan/Documents/ops-agent/.claude/hooks/youtube_guard.py"
          }
        ]
      },
      {
        "matcher": "mcp__ops__write_file",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/stephan/Documents/ops-agent/.claude/hooks/write_file_sudo_guard.py"
          }
        ]
      },
      {
        "matcher": "mcp__ops__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/stephan/Documents/ops-agent/.claude/hooks/runbook_guard.py"
          }
        ]
      },
      {
        "matcher": "mcp__ops__.*|Agent|Bash|WebFetch|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/stephan/Documents/ops-agent/.claude/hooks/budget_guard.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/stephan/Documents/ops-agent/.claude/hooks/session_autocommit.py"
          },
          {
            "type": "command",
            "command": "python3 /Users/stephan/Documents/ops-agent/.claude/hooks/verify_before_done.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/stephan/Documents/ops-agent/.claude/hooks/session_handoff_inject.py"
          },
          {
            "type": "command",
            "command": "python3 /Users/stephan/Documents/ops-agent/.claude/hooks/server_context_guard.py"
          }
        ]
      }
    ]
  }
}
