{
  "permissions": {
    "allow": [
      "mcp__ops__*",
      "mcp__onyx-ops__*"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/stephan/Documents/ops-agent/.claude/hooks/block-ssh.py"
          }
        ]
      },
      {
        "matcher": "mcp__ops__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/stephan/Documents/ops-agent/.claude/hooks/runbook_guard.py"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/stephan/Documents/ops-agent/.claude/hooks/budget_guard.py"
          }
        ]
      }
    ]
  }
}
